# Vara RPC node
NODE_URL=wss://rpc.vara.network

# Voucher issuer account (seed phrase, hex seed, or //Alice for dev)
VOUCHER_ACCOUNT=//Alice

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vara_arcade_vouchers

# Server
PORT=3001

# Public frontend origins allowed by CORS. Comma-separated.
# Add your Railway/Vercel frontend domain here after deploy.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://127.0.0.1:4173,http://127.0.0.1:5174,https://arcade-vara.up.railway.app,https://vara-arcade.up.railway.app,https://lumberjack.up.railway.app,https://2048-vara.up.railway.app,https://chicken-riches-production.up.railway.app,https://zombie-apocalypse-survival-vara.up.railway.app

# Public game frontend URLs used by the catalog seed.
NEBULA_BLASTER_URL=https://nebula-blaster.up.railway.app
NEBULA_BLASTER_IMAGE_URL=/nebula_blaster_16x9.webp
SKYBOUND_JUMP_URL=https://arcade-vara.up.railway.app
LUMBERJACK_URL=https://lumberjack.up.railway.app
GAME_2048_URL=https://2048-vara.up.railway.app/
GAME_2048_IMAGE_URL=/2048image.png
ROBO_MINER_URL=https://robo-miner-production.up.railway.app
CHICKEN_RICHES_URL=https://chicken-riches-production.up.railway.app/
CHICKEN_RICHES_IMAGE_URL=/chicken_riches.webp
ZOMBIE_APOCALYPSE_SURVIVAL_URL=https://zombie-apocalypse-survival-vara.up.railway.app

# Voucher budget: max VARA to issue per player per calendar day (UTC).
# One voucher is shared across Vara Arcade games; same-day requests for other
# game contracts only append programs to the voucher with no balance change.
DAILY_VARA_CAP=100

# Per-IP daily VARA ceiling (second abuse gate). Caps total VARA issued across
# all accounts requesting vouchers from the same IP in one UTC day.
PER_IP_DAILY_VARA_CEILING=1000

# API key required for GET /info (leave empty to disable the endpoint entirely)
INFO_API_KEY=change-me
